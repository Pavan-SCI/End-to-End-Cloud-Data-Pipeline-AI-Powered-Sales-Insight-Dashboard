{
  "name": "Azure Executive Dashboard Theme",
  "dataColors": [
    "#0078D4", 
    "#FF8C00", 
    "#50E6FF", 
    "#00188F", 
    "#00B294", 
    "#2F2F2F", 
    "#A6A6A6", 
    "#FFFFFF"
  ],
  "background": "#F3F2F1",
  "foreground": "#323130",
  "tableAccent": "#0078D4",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F3F2F1" } },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "*": [
          {
            "fontFamily": "Segoe UI",
            "titleColor": { "solid": { "color": "#2F2F2F" } },
            "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
            "dropShadow": [{ "show": true, "color": { "solid": { "color": "#E1DFDD" } }, "angle": 90, "distance": 3, "blur": 5 }]
          }
        ]
      }
    }
  }
}
